# Django 基本設定
DJANGO_DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-secure-secret-key
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,testserver
DJANGO_CSRF_TRUSTED_ORIGINS=

# 前端網址（若 Next.js 獨立部署，填正式前端網址）
STORE_FRONTEND_ORIGIN=http://localhost:3000

# OpenAI（若部署端也要使用圖片生成功能才需要）
OPENAI_API_KEY=

# NewebPay Payment MPG sandbox
NEWEBPAY_MERCHANT_ID=
NEWEBPAY_HASH_KEY=
NEWEBPAY_HASH_IV=
NEWEBPAY_PAYMENT_GATEWAY_URL=https://ccore.newebpay.com/MPG/mpg_gateway
NEWEBPAY_PAYMENT_VERSION=2.2
NEWEBPAY_PAYMENT_RESPOND_TYPE=JSON
NEWEBPAY_PAYMENT_NOTIFY_URL=
NEWEBPAY_PAYMENT_RETURN_URL=
NEWEBPAY_PAYMENT_CLIENT_BACK_URL=

# NewebPay Logistics sandbox scaffold
# 若物流沿用同一組商店代號 / HashKey / HashIV，可不另外填。
NEWEBPAY_LOGISTICS_MERCHANT_ID=
NEWEBPAY_LOGISTICS_HASH_KEY=
NEWEBPAY_LOGISTICS_HASH_IV=
NEWEBPAY_LOGISTICS_CALLBACK_URL=
NEWEBPAY_LOGISTICS_CREATE_URL=
NEWEBPAY_LOGISTICS_STATUS_URL=
